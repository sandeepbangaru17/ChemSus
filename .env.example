# Admin credentials — used for the admin panel login
ADMIN_EMAIL=director@chemsus.in
ADMIN_PASSWORD=your_secure_admin_password_here

# Secret for signing local JWT tokens (admin sessions & OTP tokens)
# Must be a long random string — change before deploying!
LOCAL_AUTH_JWT_SECRET=change_me_to_a_long_random_string
OTP_HASH_SECRET=change_me_for_production

# OTP / Transactional Email (Zoho Mail SMTP)
OTP_SMTP_HOST=smtp.zoho.in
OTP_SMTP_PORT=587
OTP_SMTP_SECURE=false
OTP_SMTP_USER=sales@chemsus.in
OTP_SMTP_PASS=your_zoho_app_password
OTP_EMAIL_FROM=ChemSus Technologies <sales@chemsus.in>

# OTP behaviour
OTP_TTL_MIN=10
OTP_RESEND_SEC=60
OTP_MAX_ATTEMPTS=5
OTP_TOKEN_TTL_MIN=30

# Database
DB_PATH=db/chemsus.sqlite
# DB_FALLBACK_PATH=/tmp/chemsus.sqlite
# DB_FORCE_FALLBACK=false

# Server
PORT=5656
# NODE_ENV=production
